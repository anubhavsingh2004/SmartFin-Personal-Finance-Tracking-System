# SmartFin SMTP Configuration for Email Budget Alerts
# Copy this file to `.env` and fill in your SMTP credentials

# Gmail SMTP Server
SMARTFIN_SMTP_HOST=smtp.gmail.com
SMARTFIN_SMTP_PORT=587

# Gmail Account Credentials
# Use an App Password (not your regular Gmail password)
# Enable 2-Step Verification on your Gmail account first
SMARTFIN_SMTP_USERNAME=[your-email@gmail.com]
SMARTFIN_SMTP_PASSWORD=your-app-password

# SMTP Security Settings
SMARTFIN_SMTP_USE_TLS=true

# Email From Address (should match SMTP_USERNAME for Gmail)
SMARTFIN_EMAIL_FROM=[your-email@gmail.com]

# Optional: Flask Secret Key
# SMARTFIN_SECRET_KEY=your-secure-random-secret-key
